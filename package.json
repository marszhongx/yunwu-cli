{
  "name": "yunwu-cli",
  "version": "1.0.2",
  "description": "Terminal-based AI roleplay chat app powered by Ink.",
  "keywords": [
    "ai",
    "chat",
    "cli",
    "ink",
    "roleplay",
    "tui"
  ],
  "homepage": "https://github.com/marszhongx/yunwu-cli#readme",
  "bugs": {
    "url": "https://github.com/marszhongx/yunwu-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marszhongx/yunwu-cli.git"
  },
  "license": "ISC",
  "author": "marszhong",
  "type": "module",
  "bin": {
    "yunwu": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup",
    "start": "node dist/cli.js",
    "lint": "oxlint --type-aware --type-check src",
    "format": "oxfmt --check src",
    "test": "vitest run",
    "check": "npm run lint && npm run format && npm run test",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "@tanstack/ai": "^0.37.0",
    "@tanstack/ai-openai": "^0.15.8",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.2",
    "ink-testing-library": "^4.0.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "undici": "^7.28.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "config.example.json"
  ],
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
